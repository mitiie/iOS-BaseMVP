<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23506"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="IAPViewController" customModule="iOS_BaseMVP" customModuleProvider="target">
            <connections>
                <outlet property="messageLabel" destination="message-label" id="outlet-message"/>
                <outlet property="titleLabel" destination="title-label" id="outlet-title"/>
                <outlet property="view" destination="view" id="owner-view"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="view">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" spacing="16" translatesAutoresizingMaskIntoConstraints="NO" id="root-stack">
                    <rect key="frame" x="24" y="304" width="345" height="244"/>
                    <subviews>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="In-App Purchase" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title-label">
                            <rect key="frame" x="0.0" y="0.0" width="345" height="34"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="This screen is presented from Home or Setting through MainRoute.iap." textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="message-label">
                            <rect key="frame" x="0.0" y="50" width="345" height="62"/>
                            <fontDescription key="fontDescription" type="system" pointSize="17"/>
                            <color key="textColor" systemColor="secondaryLabelColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="purchase-button">
                            <rect key="frame" x="0.0" y="128" width="345" height="48"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="48" id="purchase-height"/>
                            </constraints>
                            <state key="normal" title="Complete Purchase"/>
                            <buttonConfiguration key="configuration" style="filled" title="Complete Purchase" cornerStyle="medium"/>
                            <connections>
                                <action selector="purchaseTapped" destination="-1" eventType="touchUpInside" id="purchase-action"/>
                            </connections>
                        </button>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="close-button">
                            <rect key="frame" x="0.0" y="192" width="345" height="48"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="48" id="close-height"/>
                            </constraints>
                            <state key="normal" title="Close"/>
                            <buttonConfiguration key="configuration" style="tinted" title="Close" cornerStyle="medium"/>
                            <connections>
                                <action selector="closeTapped" destination="-1" eventType="touchUpInside" id="close-action"/>
                            </connections>
                        </button>
                    </subviews>
                </stackView>
            </subviews>
            <viewLayoutGuide key="safeArea" id="safe-area"/>
            <color key="backgroundColor" systemColor="systemBackgroundColor"/>
            <constraints>
                <constraint firstItem="root-stack" firstAttribute="leading" secondItem="view" secondAttribute="leading" constant="24" id="stack-leading"/>
                <constraint firstItem="root-stack" firstAttribute="trailing" secondItem="view" secondAttribute="trailing" constant="-24" id="stack-trailing"/>
                <constraint firstItem="root-stack" firstAttribute="centerY" secondItem="view" secondAttribute="centerY" id="stack-center-y"/>
            </constraints>
            <freeformSimulatedSizeMetrics key="simulatedDestinationMetrics"/>
        </view>
    </objects>
    <resources>
        <systemColor name="secondaryLabelColor">
            <color red="0.23529411764705882" green="0.23529411764705882" blue="0.2627450980392157" alpha="0.59999999999999998" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
    </resources>
</document>
